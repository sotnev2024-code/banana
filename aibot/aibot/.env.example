# ─── Bot ─────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_SECRET=random_secret_for_internal_api_calls
MINIAPP_URL=https://your-miniapp.vercel.app

# ─── API ─────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=your_random_jwt_secret_min_32_chars

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aibot
REDIS_URL=redis://localhost:6379

# ─── kie.ai ──────────────────────────────────────────
KIE_API_KEY=your_kieai_api_key

# ─── ЮKassa ──────────────────────────────────────────
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key
YUKASSA_WEBHOOK_SECRET=your_webhook_secret

# ─── Mini App (Vite) ──────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_BOT_USERNAME=your_bot_username
