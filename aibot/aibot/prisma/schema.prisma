generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  telegramId   BigInt        @unique
  username     String?
  firstName    String
  lastName     String?
  photoUrl     String?
  balance      Int           @default(0)
  totalSpent   Int           @default(0)
  isBlocked    Boolean       @default(false)
  lang         String        @default("ru")
  theme        String        @default("auto")
  minDonate    Int           @default(1)
  referralCode String        @unique @default(cuid())
  referrerId   String?
  referrer     User?         @relation("Referrals", fields: [referrerId], references: [id])
  referrals    User[]        @relation("Referrals")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Daily bonus
  lastDailyAt  DateTime?
  dailyStreak  Int           @default(0)

  generations  Generation[]
  transactions Transaction[]
  payments     Payment[]
  favorites    Favorite[]
  likes        Like[]
  comments     Comment[]
  commentLikes CommentLike[]
  notifications     Notification[]
  following         Follow[]   @relation("Following")
  followers         Follow[]   @relation("Followers")
  donationsSent     Donation[] @relation("DonationsSent")
  donationsReceived Donation[] @relation("DonationsReceived")
  reports      Report[]   @relation("ReportAuthor")
  achievements UserAchievement[]
  promoCodes   PromoCodeUsage[]
}

model Generation {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        GenerationType
  model       String
  prompt      String
  imageUrl    String?
  status      GenerationStatus @default(PENDING)
  resultUrl   String?
  kieTaskId   String?
  tokensSpent Int
  isPublic    Boolean          @default(true)
  likesCount  Int              @default(0)
  errorMsg    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  favorites    Favorite[]
  likes        Like[]
  comments     Comment[]
  reports      Report[]
  reportsCount Int              @default(0)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([isPublic, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // like, comment, reply, donate, achievement, follow
  text      String
  refId     String?  // generationId, commentId, etc
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("Following", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Donation {
  id           String   @id @default(cuid())
  fromUserId   String
  fromUser     User     @relation("DonationsSent", fields: [fromUserId], references: [id])
  toUserId     String
  toUser       User     @relation("DonationsReceived", fields: [toUserId], references: [id])
  amount       Int
  message      String?
  createdAt    DateTime @default(now())

  @@index([toUserId])
  @@index([fromUserId])
}

model Report {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation("ReportAuthor", fields: [userId], references: [id])
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id])
  reason       String     @default("inappropriate")
  createdAt    DateTime   @default(now())

  @@unique([userId, generationId])
  @@index([generationId])
}

model Like {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId, generationId])
  @@index([generationId])
}

model Comment {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  generationId String
  generation   Generation    @relation(fields: [generationId], references: [id])
  parentId     String?
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")
  text         String
  likesCount   Int           @default(0)
  createdAt    DateTime      @default(now())

  likes        CommentLike[]

  @@index([generationId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Int
  type        TransactionType
  description String
  createdAt   DateTime        @default(now())

  @@index([userId])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  amount        Int
  currency      String        @default("RUB")
  provider      PaymentProvider
  status        PaymentStatus @default(PENDING)
  externalId    String?       @unique
  tokensGranted Int
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([externalId])
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId, generationId])
  @@index([userId])
}

model Achievement {
  id          String            @id
  name        String
  description String
  icon        String
  category    String            @default("general")
  threshold   Int               @default(1)
  reward      Int               @default(0)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model PromoCode {
  id          String           @id @default(cuid())
  code        String           @unique
  tokens      Int
  maxUses     Int              @default(0)
  usedCount   Int              @default(0)
  expiresAt   DateTime?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  usages      PromoCodeUsage[]
}

model PromoCodeUsage {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([userId, promoCodeId])
}

enum GenerationType {
  IMAGE
  VIDEO
  MUSIC
  MOTION
}

enum GenerationStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  SPEND
  BONUS
  REFUND
  REFERRAL
  DAILY
  PROMO
  ACHIEVEMENT
}

enum PaymentProvider {
  YUKASSA
  STARS
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}
